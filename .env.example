# =============================================================================
# Kaplen — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# =============================================================================

# Flask
FLASK_ENV=development
SECRET_KEY=change-me-in-production
JWT_SECRET=change-me-in-production

# Database (use individual params OR DATABASE_URL, not both)
DB_HOST=localhost
DB_NAME=kaplen
DB_USER=postgres
DB_PASSWORD=yourpassword
DB_PORT=5432
# DATABASE_URL=postgresql://user:password@host/dbname

# AWS
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET=your-curriculum-bucket

# LLM provider — set one block below, leave the others blank
# Supported: anthropic (default), openai
LLM_PROVIDER=anthropic
LLM_API_KEY=          # universal key (overrides provider-specific keys below)
LLM_MODEL=            # universal model override
LLM_BASE_URL=         # optional: base URL for OpenAI-compatible endpoints (Ollama, Together, etc.)

# Anthropic (used when LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# OpenAI (used when LLM_PROVIDER=openai)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# Application
DOMAIN=localhost:5000
TIMEZONE=UTC

# Path to the frontend HTML files (dashboard, landing page)
FRONTEND_PATH=./static

# Curriculum
CURRICULUM_REGISTRY_PATH=curricula/registry.json
DEFAULT_CURRICULUM_ID=iraqi-moe-2024

# Wayl payments (optional)
WAYL_MERCHANT_TOKEN=
WAYL_WEBHOOK_SECRET=
WAYL_WEBHOOK_URL=

# Stripe (optional — stub, not fully implemented)
STRIPE_API_KEY=

# YouTube OAuth (optional)
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_OAUTH_REDIRECT_URI=
